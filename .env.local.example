# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this example file is tracked.

# Server-side only — never expose to client
ANTHROPIC_API_KEY=sk-ant-...

# Heisenberg PMI JWT (server-side, paste a fresh token when it expires)
# Get from: narrative.agent.heisenberg.so -> DevTools -> Network -> Authorization header
PMI_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Finnhub key. Get from: finnhub.io/dashboard
# Used server-side in the proxy route — keep NEXT_PUBLIC_ prefix only if you also want client access.
NEXT_PUBLIC_FINNHUB_KEY=your_finnhub_key
