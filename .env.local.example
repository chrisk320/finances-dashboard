# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this example file is tracked.

# --- Anthropic ---
# Server-side only — never expose to client
ANTHROPIC_API_KEY=sk-ant-...

# --- Finnhub ---
# Get from: finnhub.io/dashboard
NEXT_PUBLIC_FINNHUB_KEY=your_finnhub_key

# --- Heisenberg PMI (optional; manual/idle only) ---
# Get from: narrative.agent.heisenberg.so -> DevTools -> Network -> Authorization header
# Expires periodically — paste a fresh token when calls 401
PMI_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Phase B: NextAuth (Google sign-in) ---
# Generate AUTH_SECRET locally with: openssl rand -base64 32
AUTH_SECRET=your_random_32_byte_secret
# Google OAuth client (console.cloud.google.com -> APIs & Services -> Credentials)
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR-DEPLOY-URL.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Phase B: Neon Postgres (Vercel marketplace integration) ---
# Pull production values locally with: npx vercel env pull .env.local
# (The Vercel-Neon integration auto-sets both DATABASE_URL and POSTGRES_URL)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
